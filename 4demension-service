#!/bin/bash

# 4Demension Background Service Manager
# Starts the app as a background service that persists after closing windows

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WEBAPP_DIR="$SCRIPT_DIR/webapp"
PID_FILE="/tmp/4demension.pid"
LOG_FILE="/tmp/4demension.log"

start_service() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            echo "4Demension is already running (PID: $pid)"
            open http://localhost:3000
            return 0
        else
            rm -f "$PID_FILE"
        fi
    fi

    echo "Starting 4Demension background service..."
    
    cd "$WEBAPP_DIR"
    
    # Check dependencies
    if [ ! -d "node_modules" ]; then
        echo "Installing dependencies..."
        npm install
    fi
    
    # Start server in background with nohup
    nohup npm run dev > "$LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    
    # Wait for server to start
    local count=0
    while [ $count -lt 30 ]; do
        if curl -s http://localhost:3000 > /dev/null 2>&1; then
            echo "✅ 4Demension started successfully (PID: $pid)"
            open http://localhost:3000
            osascript -e 'display notification "4Demension is running in background!" with title "4Demension"'
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    
    echo "❌ Failed to start 4Demension"
    return 1
}

stop_service() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            kill "$pid" 2>/dev/null
            rm -f "$PID_FILE"
            echo "4Demension stopped"
            osascript -e 'display notification "4Demension stopped" with title "4Demension"'
        else
            rm -f "$PID_FILE"
            echo "4Demension was not running"
        fi
    else
        echo "4Demension is not running"
    fi
}

status_service() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        if ps -p "$pid" > /dev/null 2>&1; then
            echo "4Demension is running (PID: $pid)"
            echo "Access it at: http://localhost:3000"
        else
            echo "4Demension is not running (stale PID file)"
            rm -f "$PID_FILE"
        fi
    else
        echo "4Demension is not running"
    fi
}

case "$1" in
    start)
        start_service
        ;;
    stop)
        stop_service
        ;;
    restart)
        stop_service
        sleep 2
        start_service
        ;;
    status)
        status_service
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        echo ""
        echo "Commands:"
        echo "  start   - Start 4Demension in background"
        echo "  stop    - Stop 4Demension"
        echo "  restart - Restart 4Demension"
        echo "  status  - Check if 4Demension is running"
        ;;
esac
